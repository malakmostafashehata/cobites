<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controllers.CharityDashboardController"
            stylesheets="@charity.css"
            prefWidth="1150" prefHeight="680">
<!-- TOP BAR -->
<top>
    <HBox id="topBar" spacing="20" alignment="CENTER_LEFT">
        <padding>
            <Insets top="15" bottom="15" left="25" right="25"/>
        </padding>

        <!-- VBox for WELCOME + Charity Name -->
        <VBox alignment="CENTER_LEFT" spacing="5">
            <Label text="WELCOME TO COBITES" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <Label fx:id="charityNameLabel" text="Charity Name" style="-fx-font-size: 16px;"/>
        </VBox>

        <Pane HBox.hgrow="ALWAYS"/>

        <Button fx:id="btnExit" text="Exit" id="logoutBtn"/>
    </HBox>
</top>

    <!-- SIDEBAR -->
    <left>
        <VBox id="sideBar">
            <padding><Insets top="30" bottom="30" left="20" right="20"/></padding>
            <Button fx:id="btnDonations" text="Donations" styleClass="side-btn"/>
            <Button fx:id="btnHistory" text="Order History" styleClass="side-btn"/>
            <Button fx:id="btnComplaints" text="Complaints" styleClass="side-btn"/>
            <Button fx:id="btnProfile" text="Profile" styleClass="side-btn"/>
        </VBox>
    </left>

    <!-- CENTER AREA -->
    <center>
        <StackPane id="mainStack">

            <!-- DONATIONS -->
            <VBox fx:id="donationsSection" spacing="20" visible="true" styleClass="section">
                <Label text="Available Donations" styleClass="section-title"/>
                <ScrollPane fitToWidth="true" styleClass="scroll-area">
                    <FlowPane fx:id="donationsCardsContainer" hgap="15" vgap="15" prefWrapLength="600">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    </FlowPane>
                </ScrollPane>
            </VBox>

            <!-- HISTORY -->
            <VBox fx:id="historySection" spacing="20" visible="false" styleClass="section">
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Order History" styleClass="section-title"/>
                    <ComboBox fx:id="cbHistoryFilter" prefWidth="150"/>
                    <Button fx:id="btnExportHistory" text="Export CSV" styleClass="primary-btn"/>
                </HBox>
                <ScrollPane fitToWidth="true" styleClass="scroll-area">
                    <VBox fx:id="historyCardsContainer" spacing="15">
                        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                    </VBox>
                </ScrollPane>
            </VBox>

            <!-- COMPLAINTS -->
            <VBox fx:id="complaintsSection" spacing="15" visible="false" styleClass="section">
                <Label text="Submit Complaint" styleClass="section-title"/>
                <TextArea fx:id="txtComplaintDesc" promptText="Write your complaint..." prefHeight="180"/>
                <Button fx:id="btnSubmitComplaint" text="Submit" styleClass="danger-btn"/>
            </VBox>

            <!-- PROFILE -->
            <VBox fx:id="profileSection" spacing="15" visible="false" styleClass="section">
                <Label text="Profile Settings" styleClass="section-title"/>
                <Label text="Name:"/><TextField fx:id="txtProfileName"/>
                <Label text="Password:"/><PasswordField fx:id="txtProfilePassword"/>
                <Label text="Address:"/><TextField fx:id="txtProfileAddress"/>
                <HBox spacing="20">
                    <Button fx:id="btnSaveProfile" text="Save" styleClass="success-btn"/>
                    <Button fx:id="btnDeleteProfile" text="Delete Account" styleClass="danger-btn"/>
                    <Button fx:id="btnLogoutProfile" text="Logout" styleClass="primary-btn"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
