<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="gui.controllers.DonationFormController"
      spacing="15" alignment="TOP_CENTER"
      styleClass="donation-form"
      stylesheets="@dashboard.css">

    <!-- Title -->
    <Label fx:id="lblTitle" text="Add New Donation" styleClass="form-title"/>

    <!-- FORM GRID -->
    <GridPane hgap="15" vgap="12" styleClass="form-grid">

        <!-- Name -->
        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="txtName" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="form-input"/>
        <Label fx:id="errName" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="form-error"/>

        <!-- Quantity -->
        <Label text="Quantity:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
        <TextField fx:id="txtQty" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="form-input"/>
        <Label fx:id="errQty" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="form-error"/>

        <!-- Type -->
        <Label text="Type:" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
        <ComboBox fx:id="cmbType" GridPane.rowIndex="2" GridPane.columnIndex="1" prefWidth="150" styleClass="form-combo"/>

        <!-- Image -->
        <Label text="Image:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
        <HBox spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="1">
            <Button fx:id="btnBrowse" text="Browse" styleClass="btn-action"/>
            <Label fx:id="lblImage" text="No file chosen" styleClass="form-label"/>
        </HBox>

    </GridPane>

    <!-- Status Label -->
    <Label fx:id="lblStatus" text="" style="-fx-text-fill: red; -fx-font-weight: bold;"/>

    <!-- Buttons -->
    <HBox spacing="20" alignment="CENTER">
        <Button fx:id="btnSubmit" text="Submit" styleClass="btn-action"/>
        <Button fx:id="btnCancel" text="Cancel" styleClass="btn-action"/>
    </HBox>

</VBox>