<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="gui.controllers.RegisterController"
           prefWidth="800" prefHeight="600">

    <children>

        <!-- Background Image -->
        <ImageView fitWidth="800" fitHeight="600" preserveRatio="false">
            <image>
                <Image url="@/images/login.jpeg"/>
            </image>
        </ImageView>

        <!-- Transparent White Card -->
        <StackPane maxWidth="450" maxHeight="550"
                   style="-fx-background-color: rgba(255,255,255,0.85);
                          -fx-background-radius: 20;
                          -fx-padding: 30;">

            <VBox alignment="CENTER" spacing="15" maxWidth="400">

                <Label text="Register" style="-fx-font-size: 28px; -fx-font-weight: bold;" />

                <TextField fx:id="usernameField" promptText="Username" maxWidth="300"/>
                <PasswordField fx:id="passwordField" promptText="Password" maxWidth="300"/>
                <TextField fx:id="nameField" promptText="Full Name" maxWidth="300"/>
                <TextField fx:id="addressField" promptText="Address" maxWidth="300"/>
                <TextField fx:id="phoneField" promptText="Phone Number" maxWidth="300"/>

                <ComboBox fx:id="roleComboBox"
                          promptText="Select Role"
                          maxWidth="300"
                          style="
              -fx-background-color: white;
              -fx-background-radius: 20;
              -fx-border-radius: 20;
              -fx-border-color: #cccccc;
              -fx-focus-color: transparent;
              -fx-faint-focus-color: transparent;
          "/>


                <!-- Volunteer Type -->
                <HBox fx:id="volunteerTypeBox" spacing="10" alignment="CENTER_LEFT" visible="false">
                    <Label text="Volunteer Type:"/>
                    <ComboBox fx:id="volunteerTypeComboBox"
                              maxWidth="150"
                              style="
              -fx-background-color: white;
              -fx-background-radius: 15;
              -fx-border-radius: 15;
              -fx-border-color: #cccccc;
              -fx-padding: 4 8 4 8;
              -fx-focus-color: transparent;
              -fx-faint-focus-color: transparent;
          "/>
                </HBox>

                <!-- Charity Review Code -->
                <HBox fx:id="charityCodeBox" spacing="10" alignment="CENTER_LEFT" visible="false">
                    <Label text="Source Code:"/>
                    <TextField fx:id="charityCodeField" promptText="Enter your code" maxWidth="150"/>
                </HBox>

                <Button fx:id="registerButton" text="Register" maxWidth="150"
                        style="-fx-background-color: #054561; -fx-text-fill: white; -fx-font-weight: bold;"/>

                <HBox alignment="CENTER" spacing="6">
                    <Label text="Have an account?" />
                    <Label fx:id="loginHereLabel"
                           text="Login here"
                           style="-fx-text-fill: #054561; -fx-cursor: hand;" />
                </HBox>

                <Label fx:id="statusLabel"
                       text=""
                       wrapText="true"
                       maxWidth="300"
                       alignment="CENTER"
                       textAlignment="CENTER"
                       style="-fx-text-fill: red; -fx-font-size: 14px;"/>
            </VBox>
        </StackPane>

    </children>
</StackPane>