<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controllers.DeliveryDashboardController"
            stylesheets="@dashboard.css">

    <!-- ===================== TOP BAR ===================== -->
    <top>
        <VBox spacing="10" styleClass="top-bar">
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="profile-bar">

                <!-- Welcome + Delivery Name -->
                <VBox spacing="2">
                    <Label fx:id="lblWelcome" text="WELCOME TO COBITES" styleClass="welcome-label"/>
                    <GridPane hgap="10">
                        <Label text="Delivery" styleClass="header-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDeliveryName" text="Delivery Name" styleClass="header-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Right side: Profile + Logout -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="btnEditProfile" text="Profile" styleClass="btn-profile"/>
                    <Button fx:id="btnLogout" text="Logout" styleClass="btn-logout"/>
                    <Button fx:id="btnExit" text="Exit" styleClass="btn-profile"/>
                </HBox>
            </HBox>
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
        </VBox>
    </top>

    <!-- ===================== LEFT PANEL ===================== -->
    <left>
        <VBox styleClass="left-panel">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <VBox spacing="15" styleClass="filter-box">
                <Button fx:id="btnOrder" text="Order" styleClass="side-btn"/>
                <Button fx:id="btnHistory" text="History" styleClass="side-btn"/>
                <Button fx:id="btnComplaints" text="Complaints" styleClass="side-btn"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===================== CENTER ===================== -->
    <center>
        <StackPane styleClass="center-pane" style="-fx-padding: 15;">

            <!-- ================= ORDERS SECTION ================= -->
            <VBox fx:id="ordersSection" spacing="10" styleClass="section-pane">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Orders" styleClass="section-title"/>
                    <TextField fx:id="txtSearch" promptText="Search orders..." styleClass="input-field"/>
                    <ComboBox fx:id="cbStatusFilter" promptText="Select Status" styleClass="input-field"/>
                </HBox>
                <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
                <TableView fx:id="deliveryTable" VBox.vgrow="ALWAYS" styleClass="main-table">
                    <columns>
                        <TableColumn fx:id="colId" text="ID"/>
                        <TableColumn fx:id="colDonorAddress" text="Donor Address"/>
                        <TableColumn fx:id="colDonorPhone" text="Donor Phone"/>
                        <TableColumn fx:id="colCharityAddress" text="Charity Address"/>
                        <TableColumn fx:id="colCharityPhone" text="Charity Phone"/>
                        <TableColumn fx:id="colDate" text="Date"/>
                        <TableColumn fx:id="colStatus" text="Status"/>
                        <TableColumn fx:id="colAction" text="Action"/>
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT">
                    <Button fx:id="btnExportCSV" text="Export CSV" styleClass="btn-submit"/>
                </HBox>
            </VBox>

            <!-- ================= HISTORY SECTION ================= -->
            <VBox fx:id="historySection" spacing="10" styleClass="section-pane" visible="false">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="History" styleClass="section-title"/>
                    <TextField fx:id="txtHistorySearch" promptText="Search history..." styleClass="input-field"/>
        <ComboBox fx:id="cbHistoryFilter" prefWidth="150" styleClass="input-field"/>

                </HBox>

                <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="main-table">
                    <columns>
                        <TableColumn fx:id="colHistoryId" text="ID"/>
                        <TableColumn fx:id="colHistoryDonorAddress" text="Donor Address"/>
                        <TableColumn fx:id="colHistoryDonorPhone" text="Donor Phone"/>
                        <TableColumn fx:id="colHistoryCharityAddress" text="Charity Address"/>
                        <TableColumn fx:id="colHistoryCharityPhone" text="Charity Phone"/>
                        <TableColumn fx:id="colHistoryDate" text="Date"/>
                        <TableColumn fx:id="colHistoryStatus" text="Status"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ================= COMPLAINTS SECTION ================= -->
            <VBox fx:id="complaintsSection" spacing="10" styleClass="section-pane" visible="false">
                <Label text="Submit Complaint" styleClass="section-title"/>
                <TextArea fx:id="txtComplaintDesc" promptText="Describe your complaint..." prefHeight="150"/>
                <Button fx:id="btnSubmitComplaint" text="Submit Complaint" styleClass="btn-submit"/>
            </VBox>

            <!-- ================= PROFILE SECTION ================= -->
            <VBox fx:id="profileSection" spacing="10" styleClass="section-pane" visible="false">
                <Label text="Profile" styleClass="section-title"/>
                <Label text="Full Name" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <TextField fx:id="txtProfileName" promptText="Name"/>
                <Label text="Password" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <PasswordField fx:id="txtProfilePassword" promptText="Password"/>
                <Label text="Address" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <TextField fx:id="txtProfileAddress" promptText="Address"/>
                <Label text="Phone" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                <TextField fx:id="txtProfilePhone" promptText="Phone"/>
                <HBox spacing="10">
                    <Button fx:id="btnSaveProfile" text="Save" style="-fx-background-color: #2E7D32; -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 5 15;"/>
                    <Button fx:id="btnDeleteProfile" text="Delete Account" styleClass="btn-logout"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>