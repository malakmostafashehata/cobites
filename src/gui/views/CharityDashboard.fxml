<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controllers.CharityDashboardController"
            stylesheets="@charity.css">

    <!-- ===================== TOP BAR ===================== -->
    <top>
        <VBox spacing="10" styleClass="top-bar">
            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="profile-bar">

                <!-- Left: Charity Name -->
                <VBox spacing="2">
                    <Label text="WELCOME TO COBITES" styleClass="welcome-label"/>
                    <GridPane hgap="10">
                        <Label text="Charity" styleClass="header-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="charityNameLabel" text="Charity Name" styleClass="header-label" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Right Buttons -->
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button fx:id="btnProfile" text="Profile" styleClass="btn-profile"/>
                    <Button fx:id="btnTopLogout" text="Logout" styleClass="btn-logout"/>
                    <Button fx:id="btnExit" text="Exit" styleClass="btn-profile"/>
                </HBox>

            </HBox>
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
        </VBox>
    </top>

    <!-- ===================== LEFT SIDE BAR ===================== -->
    <left>
        <VBox styleClass="left-panel">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
            <VBox spacing="15" styleClass="filter-box">
                <Button fx:id="btnDonations" text="Donations" styleClass="side-btn"/>
                <Button fx:id="btnHistory" text="History" styleClass="side-btn"/>
                <Button fx:id="btnComplaints" text="Complaints" styleClass="side-btn"/>
            </VBox>
        </VBox>
    </left>

    <!-- ===================== CENTER CONTENT ===================== -->
    <center>
        <StackPane styleClass="center-pane" style="-fx-padding: 15;">

          <!-- Donations Section -->
<VBox fx:id="donationsSection" spacing="10" styleClass="section-pane " >

    <!-- ===== Title + Search & Filter ===== -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Available Donations" styleClass="section-title"/>
        <TextField fx:id="txtSearch" promptText="Search donation..." styleClass="input-field" />
        <ComboBox fx:id="cbTypeFilter" prefWidth="150" styleClass="input-field"/>
    </HBox>

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="scroll">
        <FlowPane fx:id="donationsCardsContainer" hgap="15" vgap="15" styleClass="cards-container"/>
    </ScrollPane>
</VBox>


            <!-- History Section -->
<VBox fx:id="historySection" spacing="10" styleClass="section-pane" visible="false">
    <HBox spacing="10">
        <Label fx:id="lblHistoryFilter" text="History Filter:" styleClass="label-history"/>
        <ComboBox fx:id="cbHistoryFilter" prefWidth="150" styleClass="input-field"/>
        <ComboBox fx:id="cbHistoryStatusFilter" prefWidth="150" styleClass="input-field"/>
        <Button fx:id="btnExportHistory" text="Export CSV" styleClass="btn-submit"/>
    </HBox>

    <!-- Container for history cards -->
    <VBox fx:id="historyCardsContainer" spacing="10"/>
</VBox>



            <!-- Complaints Section -->
            <VBox fx:id="complaintsSection" spacing="10" styleClass="section-pane" visible="false">
                <Label text="Submit Complaint" styleClass="section-title"/>
                <TextArea fx:id="txtComplaintDesc" promptText="Describe your complaint..." prefHeight="150"/>
                <Button fx:id="btnSubmitComplaint" text="Submit Complaint" styleClass="btn-submit"/>
            </VBox>

            <!-- Profile Section -->
            <VBox fx:id="profileSection" spacing="10" styleClass="section-pane" visible="false">
                <Label text="Profile" styleClass="section-title"/>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="scroll">
                    <VBox spacing="10" style="-fx-padding: 10;">
                                           <Label text="Full name"/>
                        <TextField fx:id="txtProfileName" promptText="Full name"/>
                        
                        <Label text="Password"/>
                        <PasswordField fx:id="txtProfilePassword" promptText="Password"/>

                       

                        <Label text="Address"/>
                        <TextField fx:id="txtProfileAddress" promptText="Address"/>

                        <Label text="Phone"/>
                        <TextField fx:id="txtProfilePhone" promptText="Phone"/>

                        <HBox spacing="10">
                            <Button fx:id="btnSaveProfile" text="Save" styleClass="btn-save"/>
                            <Button fx:id="btnDeleteProfile" text="Delete Account" styleClass="btn-logout"/>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </VBox>

        </StackPane>
    </center>
    <!-- ===================== BOTTOM PANEL ===================== -->
    <bottom>
        <HBox fx:id="bottomPanel" spacing="10" alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="READY" styleClass="status-label"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </bottom>

</BorderPane>