<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="gui.controllers.CharityDashboardController"
            prefWidth="1100" prefHeight="650">

    <!-- TOP BAR -->
    <top>
        <HBox spacing="20" style="-fx-background-color:#2758B0;">
            <padding>
                <Insets top="15" right="20" bottom="15" left="20"/>
            </padding>

            <Label text="Charity Dashboard"
                   style="-fx-text-fill:white; -fx-font-size:26px; -fx-font-weight:bold;"/>

            <Pane HBox.hgrow="ALWAYS" />
            <Button fx:id="btnExit"
                    text="Exit"
                    style="-fx-background-color:white; -fx-text-fill:#2758B0; -fx-font-weight:bold;"
                    prefWidth="90"/>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox spacing="20" style="-fx-background-color:#1D3E80;" prefWidth="220">
            <padding>
                <Insets top="25" right="20" bottom="25" left="20"/>
            </padding>

            <Button fx:id="btnDonations" text="Donations"
                    style="-fx-background-color:white; -fx-text-fill:#1D3E80; -fx-font-weight:bold;"
                    prefWidth="180"/>

            <Button fx:id="btnHistory" text="Order History"
                    style="-fx-background-color:white; -fx-text-fill:#1D3E80; -fx-font-weight:bold;"
                    prefWidth="180"/>

            <Button fx:id="btnComplaints" text="Complaints"
                    style="-fx-background-color:white; -fx-text-fill:#1D3E80; -fx-font-weight:bold;"
                    prefWidth="180"/>

            <Button fx:id="btnProfile" text="Profile"
                    style="-fx-background-color:white; -fx-text-fill:#1D3E80; -fx-font-weight:bold;"
                    prefWidth="180"/>

        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane fx:id="mainStack">
            
            <!-- DONATIONS SECTION -->
            <VBox fx:id="donationsSection" spacing="15" visible="true">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Available Donations" style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                <ScrollPane fitToWidth="true">
                    <VBox fx:id="donationsCardsContainer" spacing="15" padding="10"/>
                </ScrollPane>

            </VBox>

            <!-- HISTORY SECTION -->
            <VBox fx:id="historySection" spacing="15" visible="false">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <HBox spacing="20" alignment="CENTER_LEFT">
                    <Label text="Order History" style="-fx-font-size:22px; -fx-font-weight:bold;"/>
                    <ComboBox fx:id="cbHistoryFilter" prefWidth="150"/>
                    <Button fx:id="btnExportHistory" text="Export CSV"
                            style="-fx-background-color:#2758B0; -fx-text-fill:white; -fx-font-weight:bold;"/>
                </HBox>

                <ScrollPane fitToWidth="true">
                    <VBox fx:id="historyCardsContainer" spacing="15" padding="10"/>
                </ScrollPane>
            </VBox>

            <!-- COMPLAINTS SECTION -->
            <VBox fx:id="complaintsSection" spacing="15" visible="false">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Submit Complaint" style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                <TextArea fx:id="txtComplaintDesc"
                          promptText="Write your complaint here..."
                          prefHeight="200"/>

                <Button fx:id="btnSubmitComplaint" text="Submit"
                        style="-fx-background-color:#EA4335; -fx-text-fill:white; -fx-font-weight:bold;"
                        prefWidth="120"/>
            </VBox>

            <!-- PROFILE SECTION -->
            <VBox fx:id="profileSection" spacing="15" visible="false">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

                <Label text="Profile Settings" style="-fx-font-size:22px; -fx-font-weight:bold;"/>

                <Label text="Name:"/>
                <TextField fx:id="txtProfileName"/>

                <Label text="Password:"/>
                <PasswordField fx:id="txtProfilePassword"/>

                <Label text="Address:"/>
                <TextField fx:id="txtProfileAddress"/>

                <HBox spacing="15">
                    <Button fx:id="btnSaveProfile" text="Save"
                            style="-fx-background-color:#34A853; -fx-text-fill:white; -fx-font-weight:bold;"
                            prefWidth="120"/>

                    <Button fx:id="btnDeleteProfile" text="Delete Account"
                            style="-fx-background-color:#EA4335; -fx-text-fill:white; -fx-font-weight:bold;"
                            prefWidth="150"/>

                    <Button fx:id="btnLogoutProfile" text="Logout"
                            style="-fx-background-color:#2758B0; -fx-text-fill:white; -fx-font-weight:bold;"
                            prefWidth="120"/>
                </HBox>
            </VBox>

        </StackPane>
    </center>

</BorderPane>
